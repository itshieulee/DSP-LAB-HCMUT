clc;
clear;
close;

n = -2:1;
x = [1 -2 3 6];

// y1 = x(-n)
n1 = -1:2;
y1 = [6 3 -2 1];

figure(1)

subplot(2,1,1)
plot2d3(n,x)
plot(n,x, 'ro')
title("Original Signal x(n)")
xlabel("n")
ylabel("Amplitude")
xgrid()

subplot(2,1,2)
plot2d3(n1,y1)
plot(n1,x1, 'ro')
title("y1(n) = x(-n)")
xlabel("n")
ylabel("Amplitude")
xgrid()
