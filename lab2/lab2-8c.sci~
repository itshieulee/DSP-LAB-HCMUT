clc;
clear;
close;

n = -2:1;
x = [1 -2 3 6];

n3 = -3:0;
y3 = [12 6 -4 2];

figure(1)

subplot(2,1,1)
plot2d3(n,x)
plot(n,x, 'ro')
title("Original Signal x(n)")
xlabel("n")
ylabel("Amplitude")
xgrid()

subplot(2,1,2)
plot2d3(n3,y3)
plot(n3,y3, 'ro')
title("y3(n) = 2x(-n-2)")
xlabel("n")
ylabel("Amplitude")
xgrid()
